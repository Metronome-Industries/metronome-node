{
  "dxt_version": "0.1",
  "name": "@metronome/mcp",
  "version": "0.3.0",
  "description": "The official MCP Server for the Metronome API",
  "author": {
    "name": "Metronome",
    "email": "dev-feedback@metronome.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Metronome-Industries/metronome-node.git"
  },
  "homepage": "https://github.com/Metronome-Industries/metronome-node/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.metronome.com",
  "server": {
    "type": "node",
    "entry_point": "${__dirname}/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "METRONOME_BEARER_TOKEN": "${user_config.METRONOME_BEARER_TOKEN}",
        "METRONOME_WEBHOOK_SECRET": "${user_config.METRONOME_WEBHOOK_SECRET}"
      }
    }
  },
  "user_config": {
    "METRONOME_BEARER_TOKEN": {
      "title": "bearer_token",
      "description": "",
      "required": true,
      "type": "string"
    },
    "METRONOME_WEBHOOK_SECRET": {
      "title": "webhook_secret",
      "description": "",
      "required": false,
      "type": "string"
    }
  },
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
